{
  "manifest_version": 3,
  "name": "EducoLink Workspace Tracker",
  "version": "1.0",
  "description": "Companion extension for EducoLink to track study time and restrict distracting navigation in the Smart Workspace.",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/iframe-patch.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5174/*"
      ],
      "js": ["scripts/bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_end"
    }
  ]
}
